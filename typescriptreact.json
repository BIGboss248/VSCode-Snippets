	"Logging Setup": {
		"prefix": "!logging_setup",
		"body": [
			"import { createLogger, format, transports } from 'winston';",
			"",
			"const logger = createLogger({",
			"\tlevel: '${1:info}',",
			"\tformat: format.combine(",
			"\t\tformat.timestamp({ format: 'YYYY-MM-DD HH:mm:ss' }),",
			"\t\tformat.errors({ stack: true }),",
			"\t\tformat.splat(),",
			"\t\tformat.json()",
			"\t),",
			"\tdefaultMeta: { service: '${2:app-name}' },",
			"\ttransports: [",
			"\t\tnew transports.File({ filename: 'error.log', level: 'error' }),",
			"\t\tnew transports.File({ filename: 'combined.log' }),",
			"\t],",
			"});",
			"",
			"if (process.env.NODE_ENV !== 'production') {",
			"\tlogger.add(new transports.Console({",
			"\t\tformat: format.combine(",
			"\t\t\tformat.colorize(),",
			"\t\t\tformat.simple()",
			"\t\t),",
			"\t}));",
			"}",
			"",
