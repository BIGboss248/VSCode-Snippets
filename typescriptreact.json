{
	"React context": {
		"prefix": "!react context",
		"description": "Create react context with custom hook",
		"body": [
			"$BLOCK_COMMENT_START file ThemeContext.tsx $BLOCK_COMMENT_END",
			"import { createContext, useContext, useState, ReactNode } from \"react\";",
			"",
			"// Step1 define what data is meant to be shared",
			"interface ThemeContextValue {",
			"theme: 'light' | 'dark';",
			"toggleTheme: () => void;",
			"}",
			"// Step2 Create context with undefined default value forcing provider usage",
			"const ThemeContext = createContext<ThemeContextValue | undefined>(undefined);",
			"// Step3 Create custom hook (optional, recommended)",
			"export function useTheme() {",
			"\tconst context = useContext(ThemeContext);",
			"\t// Safety check: make sure someone didn't forget to wrap with Provider",
			"\tif (context === undefined) {",
			"\t\tthrow new Error(\"useTheme must be used inside a ThemeProvider\");",
			"\t}",
			"\treturn context;",
			"}",
			"// Step4 The provider component which holds the state and provides the value",
			"type ThemeProviderProps = {",
			"\tchildren: ReactNode;",
			"}",
			"",
			"export function ThemeProvider({ children }: Readonly<ThemeProviderProps>) {",
			"\t// We keep the theme in state",
			"\tconst [theme, setTheme] = useState<\"light\" | \"dark\">(\"light\");",
			"\t// Function to switch between light ↔ dark",
			"\tconst toggleTheme = () => {",
			"\t\tsetTheme((current) => (current === \"light\" ? \"dark\" : \"light\"));",
			"\t}",
			"",
			"\t// The value object that all consumers will receive",
			"\tconst value = {",
			"theme,",
			"toggleTheme",
			"};",
			"",
			"\treturn (",
			"\t\t<ThemeContext.Provider value={value}>",
			"\t\t\t{children}",
			"\t\t</ThemeContext.Provider>",
			"\t);",
			"}",
			""
		]
	},
